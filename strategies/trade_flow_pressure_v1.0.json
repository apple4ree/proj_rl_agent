{
  "name": "trade_flow_pressure",
  "version": "1.0",
  "description": "Trade-level buy/sell flow imbalance as directional signal. Heavy buy flow → bullish momentum, heavy sell flow → bearish. Simple two-rule design for clarity.",
  "signal_rules": [
